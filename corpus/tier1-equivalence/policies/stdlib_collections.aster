Module std.collections.

Rule length given xs, produce:
  Return List.length(xs).

Rule head given xs, produce:
  Return none.

Rule id given x, produce:
  Return x.

Rule mapId given xs, produce:
  Return List.map(xs, id).

Rule maxOf given xs, produce:
  Return List.max(xs).

Rule minOf given xs, produce:
  Return List.min(xs).
